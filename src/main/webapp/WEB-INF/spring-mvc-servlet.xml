<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:mvc="http://www.springframework.org/schema/mvc"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context.xsd
           http://www.springframework.org/schema/mvc
           http://www.springframework.org/schema/mvc/spring-mvc.xsd">

    <!-- 
        Scan this package for classes marked with @Controller, @Service etc.
        Spring will automatically detect and register them.
    -->
    <context:component-scan base-package="com.university" />

    <!-- Enable Spring MVC annotations like @GetMapping, @PostMapping -->
    <mvc:annotation-driven />

    <!-- 
        View Resolver - tells Spring where to find JSP pages.
        When a controller returns "login", Spring looks for:
        /WEB-INF/views/login.jsp
    -->
    <bean class="org.springframework.web.servlet.view.InternalResourceViewResolver">
        <property name="prefix" value="/WEB-INF/views/" />
        <property name="suffix" value=".jsp" />
    </bean>

    <!-- 
        Interceptor configuration - we will add our 
        LoggingInterceptor here in a later step 
    -->
    <mvc:interceptors>
        <bean class="com.university.interceptor.LoggingInterceptor" />
    </mvc:interceptors>

</beans>