<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- 
        DataSource - this is our database connection details.
        Like giving Java the address, username and password 
        to log into MySQL.
    -->
    <bean id="dataSource" 
          class="org.springframework.jdbc.datasource.DriverManagerDataSource">
        
        <!-- MySQL JDBC driver -->
        <property name="driverClassName" value="com.mysql.cj.jdbc.Driver" />
        
        <!-- 
            Database URL format:
            jdbc:mysql://localhost:3306/YOUR_DATABASE_NAME
        -->
        <property name="url" 
                  value="jdbc:mysql://localhost:3306/university_db?useSSL=false&amp;serverTimezone=UTC" />
        
        <!-- Your MySQL username (default is root) -->
        <property name="username" value="root" />
        
        <!-- Your MySQL password - change this to your actual password -->
        <property name="password" value="password" />
        
    </bean>

    <!-- 
        JdbcTemplate - this is the tool we use to run SQL queries.
        We inject the dataSource into it so it knows which 
        database to talk to.
    -->
    <bean id="jdbcTemplate" 
          class="org.springframework.jdbc.core.JdbcTemplate">
        <property name="dataSource" ref="dataSource" />
    </bean>

</beans>